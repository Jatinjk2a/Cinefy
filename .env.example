# ── Required secrets ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# JWT signing secret — must be at least 32 characters
JWT_SECRET=your-256-bit-secret-here-generate-with-openssl-rand-hex-32

# Your GitHub username (for GHCR image pull)
GITHUB_OWNER=Jatinjk2a

# ── Frontend API keys ─────────────────────────────────────────────────────────
# Get from https://www.omdbapi.com/apikey.aspx
VITE_OMDB_API_KEY=your-omdb-api-key-here

# Get from https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# Get from https://console.developers.google.com/
VITE_YOUTUBE_API_KEY=your-youtube-api-key-here

# ── Optional: Mail (notification-service) ─────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
